{
  "name": "example-otlp-exporter-node",
  "private": true,
  "version": "0.202.0",
  "description": "Example of using @opentelemetry/collector-exporter in Node.js",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:tracing": "node tracing.js",
    "start:metrics": "node metrics.js",
    "docker:start": "cd ./docker && docker-compose down && docker-compose up",
    "docker:startd": "cd ./docker && docker-compose down && docker-compose up -d",
    "docker:stop": "cd ./docker && docker-compose down",
    "align-api-deps": "node ../../scripts/align-api-deps.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/open-telemetry/opentelemetry-js.git"
  },
  "keywords": [
    "opentelemetry",
    "tracing"
  ],
  "engines": {
    "node": "^18.19.0 || >=20.6.0"
  },
  "author": "OpenTelemetry Authors",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/open-telemetry/opentelemetry-js/issues"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.828.0",
    "@opentelemetry/api": "file:../../../opentelemetry-js/api",
    "@opentelemetry/auto-instrumentations-node": "file:../../packages/auto-instrumentations-node",
    "@opentelemetry/core": "file:../../../opentelemetry-js/packages/opentelemetry-core",
    "@opentelemetry/exporter-metrics-otlp-grpc": "0.202.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.202.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.202.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.202.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.202.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.202.0",
    "@opentelemetry/instrumentation-fs": "file:../../plugins/node/instrumentation-fs",
    "@opentelemetry/resource-detector-aws": "file:../../detectors/node/opentelemetry-resource-detector-aws",
    "@opentelemetry/resources": "file:../../../opentelemetry-js/packages/opentelemetry-resources/package.json",
    "@opentelemetry/sdk-metrics": "2.0.1",
    "@opentelemetry/sdk-node": "file:../../../opentelemetry-js/experimental/packages/opentelemetry-sdk-node",
    "@opentelemetry/sdk-trace-node": "file:../../../opentelemetry-js/packages/opentelemetry-sdk-trace-node",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "json-bigint": "^1.0.0"
  },
  "homepage": "https://github.com/open-telemetry/opentelemetry-js/tree/main/examples/otlp-exporter-node"
}
